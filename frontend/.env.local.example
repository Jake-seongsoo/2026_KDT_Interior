# =============================================================================
# 프론트엔드 환경변수 템플릿 (Next.js / Vercel)
# 이 파일을 .env.local로 복사 후 실제 값을 채워서 사용
# cp .env.local.example .env.local
#
# NEXT_PUBLIC_ 접두사: 브라우저에 노출됨 (민감 정보 금지)
# 접두사 없는 변수: 서버 컴포넌트 / API Route에서만 접근 가능
# =============================================================================

# --- 앱 기본 설정 ---
NEXT_PUBLIC_ENVIRONMENT=development

# --- 백엔드 API URL ---
# 로컬: http://localhost:8000  |  배포: https://your-backend.run.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- Supabase (브라우저 클라이언트용) ---
# Supabase 대시보드 > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
