# =============================================================================
# 백엔드 환경변수 템플릿 (git 추적용 — 실제 값 없음)
# 이 파일을 .env로 복사 후 실제 값을 채워서 사용
# cp .env.example .env
# =============================================================================

# --- 앱 기본 설정 ---
ENVIRONMENT=development

# --- Anthropic (Claude Sonnet 4.6 / claude-sonnet-4-6) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- GCP (Vertex AI Imagen 4 + Cloud Storage) ---
# GCP 콘솔 > 프로젝트 선택 > 프로젝트 ID 확인
GCP_PROJECT_ID=your-gcp-project-id
# Vertex AI 지원 리전 (서울: asia-northeast3)
GCP_REGION=asia-northeast3
# Cloud Storage 버킷 이름 (직접 생성 필요)
GCS_BUCKET_NAME=interior-floorplans
GCS_RENDER_BUCKET_NAME=interior-renders-public
# 로컬 개발용 서비스 계정 키 경로 (Cloud Run에서는 불필요)
GOOGLE_APPLICATION_CREDENTIALS=./backend/service-account.json

# --- Supabase ---
# Supabase 대시보드 > Project Settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Supabase 대시보드 > Project Settings > API > JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- 네이버 쇼핑 API ---
# https://developers.naver.com/apps/ > 애플리케이션 등록
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-app.vercel.app

# --- 보안 / 운영 설정 ---
SIGNED_URL_TTL_MINUTES=15
CACHE_TTL_HOURS=24
